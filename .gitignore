# =============================================================================
# Node.js & TypeScript
# =============================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# TypeScript
*.tsbuildinfo
*.d.ts.map

# =============================================================================
