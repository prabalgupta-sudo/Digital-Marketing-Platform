# Digital Marketing Planning Platform - Environment Variables Example
# Copy this file to .env and fill in the actual values

# =============================================================================
# MongoDB Configuration
# =============================================================================
MONGO_USERNAME=admin
MONGO_PASSWORD=your_secure_password_here

# =============================================================================
# Service Configuration
# =============================================================================
NODE_ENV=development

# =============================================================================
# JWT Configuration
# =============================================================================
JWT_ISSUER=https://auth.marketing-platform.com
JWT_SECRET=your_jwt_secret_here
JWKS_ENDPOINT=https://auth.marketing-platform.com/.well-known/jwks.json

# =============================================================================
# Service Ports
# =============================================================================
USER_SERVICE_PORT=4001
CAMPAIGN_SERVICE_PORT=4002
ANALYTICS_SERVICE_PORT=4003
WUNDERGRAPH_PORT=9999

# =============================================================================
# Database URIs (Optional - if not using docker-compose defaults)
# =============================================================================
USER_SERVICE_MONGODB_URI=mongodb://admin:your_secure_password_here@localhost:27017/user-service?authSource=admin
CAMPAIGN_SERVICE_MONGODB_URI=mongodb://admin:your_secure_password_here@localhost:27017/campaign-service?authSource=admin
ANALYTICS_SERVICE_MONGODB_URI=mongodb://admin:your_secure_password_here@localhost:27017/analytics-service?authSource=admin
MAIN_MONGODB_URI=mongodb://localhost:27017/marketing-platform

# =============================================================================
# Redis Configuration (Optional)
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# =============================================================================
# AI Service Configuration (Optional)
# =============================================================================
AI_SERVICE_PORT=4004
AI_MODEL_PATH=
AI_API_KEY=

# =============================================================================
# Monitoring & Logging (Optional)
# =============================================================================
LOG_LEVEL=info
SENTRY_DSN=
DATADOG_API_KEY=

# =============================================================================
# Email Configuration (Optional)
# =============================================================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# =============================================================================
# Third-Party APIs (Optional)
# =============================================================================
GOOGLE_ADS_API_KEY=
META_ADS_API_KEY=
TIKTOK_API_KEY=
